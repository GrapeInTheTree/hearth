{
  "name": "@discord-bot/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and typed client.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "prisma generate && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo prisma/generated",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "6.1.0"
  },
  "devDependencies": {
    "@discord-bot/eslint-config": "workspace:*",
    "@discord-bot/tsconfig": "workspace:*",
    "@types/node": "22.10.2",
    "eslint": "9.17.0",
    "prisma": "6.1.0",
    "tsup": "8.3.5",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
