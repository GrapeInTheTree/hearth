{
  "name": "@hearth/database",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, migrations, and typed client for Hearth.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "default": "./dist/migrate.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@hearth/eslint-config": "workspace:*",
    "@hearth/tsconfig": "workspace:*",
    "@types/node": "22.10.2",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.17.0",
    "tsup": "8.3.5",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
