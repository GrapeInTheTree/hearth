{
  "name": "@hearth/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and typed client.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://placeholder@localhost:5432/placeholder} prisma generate && tsup",
    "dev": "tsup --watch",
    "typecheck": "DATABASE_URL=${DATABASE_URL:-postgresql://placeholder@localhost:5432/placeholder} prisma generate && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo prisma/generated",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://placeholder@localhost:5432/placeholder} prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@hearth/eslint-config": "workspace:*",
    "@hearth/tsconfig": "workspace:*",
    "@types/node": "22.10.2",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.17.0",
    "prisma": "7.8.0",
    "tsup": "8.3.5",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
