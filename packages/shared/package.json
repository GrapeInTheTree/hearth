{
  "name": "@hearth/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-app types, errors, Result helpers.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@hearth/eslint-config": "workspace:*",
    "@hearth/tsconfig": "workspace:*",
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "tsup": "8.3.5",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
