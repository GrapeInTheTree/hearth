# Example nginx site config for the Hearth dashboard. Copy to
# /etc/nginx/sites-available/<your-domain>, swap `dashboard.example.com`
# below for your actual subdomain, then run
# `sudo certbot --nginx -d <your-domain>` to install the TLS cert.
# Reload with `sudo systemctl reload nginx`.
#
# This file lives in infra/ as documentation. Do not deploy by
# symlinking from sites-enabled/ — copy and edit per host.

server {
  listen 443 ssl http2;
  server_name dashboard.example.com;

  # certbot manages these — adjust to your cert location.
  ssl_certificate     /etc/letsencrypt/live/dashboard.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/dashboard.example.com/privkey.pem;

  # The Next.js standalone server doesn't accept large payloads — settings
  # forms are tiny. 2 MB stops accidental file uploads at the proxy.
  client_max_body_size 2m;

  location / {
    proxy_pass         http://127.0.0.1:3200;
    proxy_http_version 1.1;

    # Standard upstream headers
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;

    # WebSocket / Server Actions stream support
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        "upgrade";

    # Server Actions can take a few seconds (panel render → bot HTTP →
    # Discord). 5 minutes is generous; tighten if it ever matters.
    proxy_read_timeout 300s;
  }
}

# Force HTTPS — operators should never reach the dashboard over plain
# HTTP since cookies are Secure-flagged.
server {
  listen 80;
  server_name dashboard.example.com;
  return 301 https://$host$request_uri;
}
