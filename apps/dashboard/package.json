{
  "name": "@hearth/dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Web dashboard — Next.js + Discord OAuth + Server Actions.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://placeholder@localhost:5432/placeholder} DISCORD_CLIENT_ID=${DISCORD_CLIENT_ID:-123456789012345678} DISCORD_CLIENT_SECRET=${DISCORD_CLIENT_SECRET:-placeholder-build-only-secret-XXXXXX} NEXTAUTH_URL=${NEXTAUTH_URL:-http://localhost:3200} NEXTAUTH_SECRET=${NEXTAUTH_SECRET:-placeholder-build-only-secret-XXXXXX-pad-to-32} BOT_INTERNAL_URL=${BOT_INTERNAL_URL:-http://localhost:3100} INTERNAL_API_TOKEN=${INTERNAL_API_TOKEN:-placeholder-build-only-token-pad-to-32-chars} BOT_NAME=${BOT_NAME:-DashboardBuildPlaceholder} next build",
    "dev": "next dev --port ${PORT:-3200}",
    "start": "next start --port ${PORT:-3200}",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@hearth/database": "workspace:*",
    "@hearth/shared": "workspace:*",
    "@hearth/tickets-core": "workspace:*",
    "@hookform/resolvers": "3.10.0",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.11.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.54.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@hearth/eslint-config": "workspace:*",
    "@hearth/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "2.1.8",
    "drizzle-orm": "0.45.2",
    "eslint": "9.17.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "postcss": "8.5.12",
    "tailwindcss": "4.2.4",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
