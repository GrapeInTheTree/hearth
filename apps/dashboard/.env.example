# ────────────────────────────────────────────────────────────────────
# Discord OAuth — required
# ────────────────────────────────────────────────────────────────────
# From Developer Portal → OAuth2. Add the redirect URI to the app's
# allowed list before signing in:
#   http://localhost:3200/api/auth/callback/discord  (dev)
#   https://<your-domain>/api/auth/callback/discord  (prod)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ────────────────────────────────────────────────────────────────────
# NextAuth — required
# ────────────────────────────────────────────────────────────────────
# Public-facing URL of the dashboard. localhost in dev, your domain in
# prod. NextAuth uses this to build OAuth callback URLs.
NEXTAUTH_URL=http://localhost:3200

# Random 32+ byte secret used to sign session JWTs. Generate:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# ────────────────────────────────────────────────────────────────────
# Database — same Postgres as the bot
# ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bot:bot@localhost:5432/discord_bot?schema=public

# ────────────────────────────────────────────────────────────────────
# Bot internal API
# ────────────────────────────────────────────────────────────────────
# In compose: http://bot:3000 (service-name DNS). On host (pnpm dev):
# http://localhost:3100 (BOT_HEALTH_PORT default).
BOT_INTERNAL_URL=http://localhost:3100

# Shared secret. MUST match the bot's INTERNAL_API_TOKEN.
# Generate once: openssl rand -hex 32
INTERNAL_API_TOKEN=

# ────────────────────────────────────────────────────────────────────
# Branding (mirror bot)
# ────────────────────────────────────────────────────────────────────
BOT_NAME=Hearth
BOT_BRAND_COLOR="#FF6B35"
BOT_ICON_URL=
BOT_FOOTER_TEXT=
BOT_SUPPORT_URL=
BOT_LOCALE=en

# ────────────────────────────────────────────────────────────────────
# Optional
# ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
PORT=3200
NODE_ENV=development
