{
  "name": "@hearth/bot",
  "version": "0.0.0",
  "private": true,
  "description": "Discord bot runtime — the deployable.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node --env-file-if-exists=.env dist/index.js\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=1 vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@hearth/database": "workspace:*",
    "@hearth/role-picker-core": "workspace:*",
    "@hearth/reaction-roles-core": "workspace:*",
    "@hearth/shared": "workspace:*",
    "@hearth/tickets-core": "workspace:*",
    "@hearth/verification-core": "workspace:*",
    "@sapphire/framework": "5.5.0",
    "@sapphire/pieces": "4.4.1",
    "@sapphire/plugin-logger": "4.0.2",
    "@sapphire/utilities": "3.18.2",
    "discord.js": "14.26.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@hearth/eslint-config": "workspace:*",
    "@hearth/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "22.10.2",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "2.1.8",
    "drizzle-orm": "0.45.2",
    "eslint": "9.17.0",
    "pg": "8.20.0",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
}
