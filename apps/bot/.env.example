# ────────────────────────────────────────────────────────────────────
# Discord — required
# ────────────────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Bot → Reset Token.
# NEVER commit a real token. This repo is PUBLIC.
DISCORD_TOKEN=

# Application ID (snowflake) from Developer Portal → General Information.
DISCORD_APP_ID=

# Optional: register slash commands to a single dev guild for instant updates.
# Without this, commands register globally (~1h propagation).
DISCORD_DEV_GUILD_ID=

# ────────────────────────────────────────────────────────────────────
# Branding — white-label per-deployment
# ────────────────────────────────────────────────────────────────────
BOT_NAME=Fannie
# Hex color must be quoted — `#` would otherwise be parsed as start-of-comment
BOT_BRAND_COLOR="#FF6B35"
BOT_ICON_URL=
BOT_FOOTER_TEXT=
BOT_SUPPORT_URL=
BOT_LOCALE=en

# ────────────────────────────────────────────────────────────────────
# Database — required from Phase 1 onward
# ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bot:bot@localhost:5432/discord_bot?schema=public

# ────────────────────────────────────────────────────────────────────
# Tickets — optional. Per-type config (panel channel, active category,
# support roles, etc.) is operator-driven via /panel + /panel ticket-type
# slash commands.
# ────────────────────────────────────────────────────────────────────
# Category that closed tickets are moved to. Can also be set via
# /setup archive-category.
TICKET_ARCHIVE_CATEGORY_ID=
# Channel that receives audit-log embeds when tickets are deleted. Can
# also be set via /setup log-channel.
BOT_LOG_CHANNEL_ID=

# ────────────────────────────────────────────────────────────────────
# Observability
# ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ────────────────────────────────────────────────────────────────────
# Server
# ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
